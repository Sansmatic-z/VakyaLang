# वाक् मानक पुस्तकालय परीक्षण (Standard Library Test)
# Updated to use correct import syntax
आयात stdlib.mool

मुद्रय "── १. गणित उपकरण परीक्षण ──"
चर सं = ५
मुद्रय सं, "! =", mool.भाज्यफल(सं)
मुद्रय "१० सम है?", mool.सम_है(१०)
मुद्रय "११ विषम है?", mool.विषम_है(११)
मुद्रय "१७ अभाज्य है?", mool.अभाज्य_है(१७)
मुद्रय "२० तक अभाज्य:", mool.अभाज्य_सूची(२०)
मुद्रय "GCD(४८, १८):", mool.महत्तम_समापवर्तक(४८, १८)

मुद्रय "\n── २. सूची उपकरण परीक्षण ──"
चर सू = [१, २, ३, ४, ५]
कर्म दुगुना(व): प्रत्यागच्छ व * २
मुद्रय "मूल:", सू
मुद्रय "दुगुना चित्रण:", mool.चित्रण(सू, दुगुना)

कर्म केवल_सम(व): प्रत्यागच्छ व % २ == ०
मुद्रय "केवल सम छानना:", mool.छानना(सू, केवल_सम)

मुद्रय "\n── ३. तार उपकरण परीक्षण ──"
मुद्रय "दोहराओ('वाक् ', ३):", mool.दोहराओ("वाक् ", ३)
मुद्रय "उलटा('नमस्ते'):", mool.उलटा_तार("नमस्ते")
मुद्रय "'नमन' पैलिंड्रोम है?", mool.पैलिंड्रोम_है("नमन")

मुद्रय "\nसभी मानक पुस्तकालय परीक्षण सफल!"
