# वाक् भाषा — नमस्ते जगत् (Hello World)
# The first program in any language

मुद्रय "नमस्ते जगत्!"
मुद्रय "Hello, World!"
मुद्रय "वाक् भाषा में आपका स्वागत है।"

# चर (variables)
चर नाम = "राज"
चर वर्ष = २०२६

मुद्रय "लेखक:", नाम
मुद्रय "वर्ष:", वर्ष

# तार संयोजन (string concatenation)
चर अभिवादन = "नमस्ते, " + नाम + "!"
मुद्रय अभिवादन

# स्थिर (constants)
स्थिर पाई_मान = ३.१४१५९
मुद्रय "π =", पाई_मान
