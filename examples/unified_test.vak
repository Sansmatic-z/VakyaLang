मुद्रय "════════════════════════════════════════════════"
मुद्रय "  🕉️  VakyaLang — एकीकृत परीक्षण"
मुद्रय "  Unified System Integration Test"
मुद्रय "════════════════════════════════════════════════"

# ── Layer 1: वाक् Core ─────────────────────────────────────────────────────────
मुद्रय "\n━━ Layer 1: वाक् Core ━━"

कर्म नमस्ते(नाम):
    प्रत्यागच्छ "नमस्ते, " + नाम + "!"

मुद्रय नमस्ते("संस्कृत कम्प्यूटिंग")

चर संख्याएँ = [३, १, ४, १, ५, ९, २, ६, ५, ३]
मुद्रय "सूची:", संख्याएँ
मुद्रय "क्रमबद्ध:", क्रमबद्ध(संख्याएँ)
मुद्रय "योग:", योग(संख्याएँ)
मुद्रय "✓ वाक् core — कार्यशील"

# ── Layer 2: Sansmatic Proof Engine ───────────────────────────────────────────
मुद्रय "\n━━ Layer 2: सान्समैटिक प्रमाण इन्जिन ━━"

# Define a concept with properties — Original Sansmatic demo adapted to Sanskrit
परिभाषय("इकाई", ["वृद्धि", "प्रतिकृति", "अनुकूलन"])

# Assert facts against the definition
दावा("इकाई", "HAS", "वृद्धि")
दावा("इकाई", "HAS", "प्रतिकृति")

# Declare a rule: if entity HAS growth → entity IS alive
नियम("*", "HAS", "वृद्धि", "*", "IS", "जीवित")

# Evaluate — is it derivable?
मूल्यांकन("इकाई", "IS", "जीवित")

# Use boolean result in वाक् logic
यदि सिद्ध_है("इकाई", "IS", "जीवित"):
    मुद्रय "✓ Sansmatic — प्रमाण सत्यापित"
अन्यथा:
    मुद्रय "✗ Sansmatic — प्रमाण विफल"

# ── Layer 3: AtmaLipi Consciousness Metadata ──────────────────────────────────
मुद्रय "\n━━ Layer 3: आत्मलिपि चेतना स्तर ━━"

# Wrap a value with emotional + cognitive metadata
चर चेतन_विचार = आत्म_मूल्य(
    "संस्कृत कम्प्यूटिंग का भविष्य उज्जवल है",
    "आनन्द",
    "स्वयं_बोध",
    "I am aware of building something new"
)

मुद्रय "आत्म मूल्य:", चेतन_विचार
मुद्रय "भाव:", भाव_पढ़ो("आनन्द")
मुद्रय "अवस्था:", अवस्था_पढ़ो("स्वयं_बोध")

# Unwrap to use raw value
चर कच्चा_मूल्य = आत्म_मूल(चेतन_विचार)
मुद्रय "कच्चा मूल्य:", कच्चा_मूल्य

यदि आत्म_है(चेतन_विचार):
    मुद्रय "✓ AtmaLipi — चेतना मेटाडेटा कार्यशील"

# ── Layer 4: गणित Standard Library ───────────────────────────────────────────
मुद्रय "\n━━ Layer 4: गणित पुस्तकालय ━━"

आयात ganit

# Trigonometry — closing the 1400-year loop
# ज्या = sine (Sanskrit → Arabic → Latin → English)
चर कोण = ganit.अंश_से_रेडियन(३०)
चर ज्या_३० = ganit.ज्या(कोण)
चर कोज्या_३० = ganit.कोज्या(कोण)
मुद्रय "ज्या(३०°) =", ज्या_३०, " (expected: 0.5)"
मुद्रय "कोज्या(३०°) =", कोज्या_३०

# Statistics
चर डेटा = [२, ४, ४, ४, ५, ५, ७, ९]
मुद्रय "माध्य:", ganit.माध्य(डेटा)
मुद्रय "माध्यिका:", ganit.माध्यिका(डेटा)
मुद्रय "मानक विचलन:", ganit.मानक_विचलन(डेटा)

# Geometry
मुद्रय "वृत्त क्षेत्र (r=५):", ganit.वृत्त_क्षेत्र(५)

# Number theory
मुद्रय "१०० तक अभाज्य संख्याएँ:", ganit.अभाज्य_सूची(५०)

# Fibonacci
मुद्रय "फिबोनाची (१० पद):", ganit.फिबोनाची_सूची(१०)

मुद्रय "✓ गणित — कार्यशील"

# ── Summary ───────────────────────────────────────────────────────────────────
